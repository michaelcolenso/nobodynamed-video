SATORI_URL=http://localhost:3001
D1_URL=https://api.cloudflare.com/client/v4/accounts/<acct>/d1/database/<db>/query
# D1_TOKEN=<optional scoped token; if unset, the repo uses `wrangler auth token`>
OUT_DIR=./out
RELEASE_DIR=./releases
FONT_DIR=./satori-service/fonts
# test | preview | publish. Publish rejects synthetic data and stale overrides.
DATA_MODE=test
# 0 derives the newest complete year from the active source.
LATEST_YEAR=0
# For official local imports: python scripts/fetch_ssa.py --out data/ssa.sqlite
SQLITE_FIXTURE=./fixtures/ssa.sqlite
LOG_LEVEL=INFO
